# Send Signal — Environment Variables
# Copy this to .env.local and fill in real values

# ── Database ──────────────────────────────────────
DATABASE_URL="postgresql://username:password@localhost:5432/send_signal"

# ── Authentication ────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET="replace-with-a-strong-random-secret-min-32-chars"

# ── Encryption (for WhatsApp credentials) ─────────
# Generate with: openssl rand -hex 16
ENCRYPTION_KEY="replace-with-32-character-key!!"

# ── App ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
