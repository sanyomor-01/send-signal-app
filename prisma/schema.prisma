// This is the Send Signal Prisma schema
// Source of truth: database_schema.md
// ORM: Prisma | DB: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum LeadStatus {
  NEW
  CONTACTED
  REPLIED
  INTERESTED
  NOT_INTERESTED
  CONVERTED
  BOUNCED
  UNSUBSCRIBED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  CANCELLED
  FAILED
}

enum MessageStatus {
  QUEUED
  SENDING
  SENT
  FAILED
  DELIVERED
  READ
  REPLIED
  UNSUBSCRIBED
  CONVERTED
  BOUNCED
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum EventType {
  CAMPAIGN_CREATED
  CAMPAIGN_STARTED
  CAMPAIGN_PAUSED
  CAMPAIGN_COMPLETED
  LEAD_IMPORTED
  LEAD_UPDATED
  LEAD_UNSUBSCRIBED
  TEMPLATE_CREATED
  TEMPLATE_UPDATED
  MESSAGE_QUEUED
  MESSAGE_SENT
  MESSAGE_FAILED
  MESSAGE_DELIVERED
  MESSAGE_READ
  REPLY_RECEIVED
  CONVERSION_RECORDED
}

enum ConversationSource {
  CAMPAIGN
  MANUAL
  WEBHOOK
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  companyName  String   @map("company_name")
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(OWNER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sessions           Session[]
  whatsappAccounts   WhatsappAccount[]
  leads              Lead[]
  leadTags           LeadTag[]
  templates          Template[]
  campaigns          Campaign[]
  messages           Message[]
  conversations      Conversation[]
  activityLogs       ActivityLog[]
  analyticsSnapshots AnalyticsSnapshot[]

  @@map("users")
}

// ─────────────────────────────────────────────
// SESSIONS
// ─────────────────────────────────────────────

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ─────────────────────────────────────────────
// WHATSAPP ACCOUNTS
// ─────────────────────────────────────────────

model WhatsappAccount {
  id                        String   @id @default(uuid())
  userId                    String   @map("user_id")
  accountName               String   @map("account_name")
  phoneNumberId             String   @unique @map("phone_number_id")
  businessAccountId         String   @map("business_account_id")
  accessTokenEncrypted      String   @map("access_token_encrypted")
  webhookVerifyTokenEncrypted String? @map("webhook_verify_token_encrypted")
  displayPhoneNumber        String?  @map("display_phone_number")
  isActive                  Boolean  @default(true) @map("is_active")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads              Lead[]
  campaigns          Campaign[]
  messages           Message[]
  conversations      Conversation[]

  @@index([userId])
  @@index([businessAccountId])
  @@map("whatsapp_accounts")
}

// ─────────────────────────────────────────────
// LEADS
// ─────────────────────────────────────────────

model Lead {
  id                 String      @id @default(uuid())
  userId             String      @map("user_id")
  whatsappAccountId  String?     @map("whatsapp_account_id")
  phoneNumber        String      @map("phone_number")
  firstName          String?     @map("first_name")
  lastName           String?     @map("last_name")
  email              String?
  source             String?
  customFieldsJson   Json?       @map("custom_fields_json")
  optIn              Boolean     @default(false) @map("opt_in")
  unsubscribed       Boolean     @default(false)
  unsubscribedAt     DateTime?   @map("unsubscribed_at")
  status             LeadStatus  @default(NEW)
  notes              String?
  deletedAt          DateTime?   @map("deleted_at")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  whatsappAccount   WhatsappAccount? @relation(fields: [whatsappAccountId], references: [id])
  campaignLeads     CampaignLead[]
  messages          Message[]
  activityLogs      ActivityLog[]
  conversationMessages ConversationMessage[]
  tagAssignments    LeadTagAssignment[]
  conversations     Conversation[]

  @@unique([userId, phoneNumber])
  @@index([userId])
  @@index([phoneNumber])
  @@index([status])
  @@index([unsubscribed])
  @@index([optIn])
  @@map("leads")
}

// ─────────────────────────────────────────────
// LEAD TAGS
// ─────────────────────────────────────────────

model LeadTag {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  color     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments LeadTagAssignment[]

  @@unique([userId, name])
  @@index([userId])
  @@map("lead_tags")
}

// ─────────────────────────────────────────────
// LEAD TAG ASSIGNMENTS
// ─────────────────────────────────────────────

model LeadTagAssignment {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  tagId     String   @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")

  lead Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag  LeadTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([leadId, tagId])
  @@map("lead_tag_assignments")
}

// ─────────────────────────────────────────────
// TEMPLATES
// ─────────────────────────────────────────────

model Template {
  id                  String   @id @default(uuid())
  userId              String   @map("user_id")
  name                String
  body                String
  placeholderSchemaJson Json?  @map("placeholder_schema_json")
  previewExampleJson  Json?    @map("preview_example_json")
  isArchived          Boolean  @default(false) @map("is_archived")
  version             Int      @default(1)
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  @@unique([userId, name, version])
  @@index([userId])
  @@map("templates")
}

// ─────────────────────────────────────────────
// CAMPAIGNS
// ─────────────────────────────────────────────

model Campaign {
  id                String         @id @default(uuid())
  userId            String         @map("user_id")
  whatsappAccountId String         @map("whatsapp_account_id")
  templateId        String         @map("template_id")
  name              String
  description       String?
  status            CampaignStatus @default(DRAFT)
  scheduledAt       DateTime?      @map("scheduled_at")
  startedAt         DateTime?      @map("started_at")
  completedAt       DateTime?      @map("completed_at")
  batchSize         Int            @default(10) @map("batch_size")
  delayInSeconds    Int            @default(5) @map("delay_in_seconds")
  totalRecipients   Int            @default(0) @map("total_recipients")
  totalQueued       Int            @default(0) @map("total_queued")
  totalSent         Int            @default(0) @map("total_sent")
  totalDelivered    Int            @default(0) @map("total_delivered")
  totalRead         Int            @default(0) @map("total_read")
  totalReplied      Int            @default(0) @map("total_replied")
  totalConverted    Int            @default(0) @map("total_converted")
  totalFailed       Int            @default(0) @map("total_failed")
  totalUnsubscribed Int            @default(0) @map("total_unsubscribed")
  deletedAt         DateTime?      @map("deleted_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  whatsappAccount   WhatsappAccount     @relation(fields: [whatsappAccountId], references: [id])
  template          Template            @relation(fields: [templateId], references: [id])
  campaignLeads     CampaignLead[]
  messages          Message[]
  activityLogs      ActivityLog[]
  analyticsSnapshots AnalyticsSnapshot[]
  conversationMessages ConversationMessage[]

  @@index([userId])
  @@index([status])
  @@index([scheduledAt])
  @@map("campaigns")
}

// ─────────────────────────────────────────────
// CAMPAIGN LEADS (execution queue)
// ─────────────────────────────────────────────

model CampaignLead {
  id             String        @id @default(uuid())
  campaignId     String        @map("campaign_id")
  leadId         String        @map("lead_id")
  status         MessageStatus @default(QUEUED)
  excludedReason String?       @map("excluded_reason")
  scheduledFor   DateTime?     @map("scheduled_for")
  processedAt    DateTime?     @map("processed_at")
  attemptCount   Int           @default(0) @map("attempt_count")
  lastAttemptAt  DateTime?     @map("last_attempt_at")
  nextAttemptAt  DateTime?     @map("next_attempt_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead     Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([campaignId, leadId])
  @@index([campaignId])
  @@index([leadId])
  @@map("campaign_leads")
}

// ─────────────────────────────────────────────
// MESSAGES
// ─────────────────────────────────────────────

model Message {
  id                String           @id @default(uuid())
  userId            String           @map("user_id")
  whatsappAccountId String           @map("whatsapp_account_id")
  campaignId        String?          @map("campaign_id")
  leadId            String           @map("lead_id")
  campaignLeadId    String?          @map("campaign_lead_id")
  direction         MessageDirection
  status            MessageStatus    @default(QUEUED)
  whatsappMessageId String?          @unique @map("whatsapp_message_id")
  templateSnapshot  Json?            @map("template_snapshot")
  renderedBody      String?          @map("rendered_body")
  failureReason     String?          @map("failure_reason")
  retryCount        Int              @default(0) @map("retry_count")
  lastRetryAt       DateTime?        @map("last_retry_at")
  queuedAt          DateTime?        @map("queued_at")
  sendingAt         DateTime?        @map("sending_at")
  sentAt            DateTime?        @map("sent_at")
  deliveredAt       DateTime?        @map("delivered_at")
  readAt            DateTime?        @map("read_at")
  repliedAt         DateTime?        @map("replied_at")
  bouncedAt         DateTime?        @map("bounced_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  whatsappAccount WhatsappAccount  @relation(fields: [whatsappAccountId], references: [id])
  campaign        Campaign?        @relation(fields: [campaignId], references: [id])
  lead            Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaignLead    CampaignLead?    @relation(fields: [campaignLeadId], references: [id])
  messageEvents   MessageEvent[]
  conversationMessages ConversationMessage[]

  // Idempotency: one outbound message per lead per campaign
  @@unique([campaignId, leadId, direction])
  @@index([campaignId])
  @@index([leadId])
  @@index([status])
  @@index([direction])
  @@index([sentAt])
  @@map("messages")
}

// ─────────────────────────────────────────────
// MESSAGE EVENTS
// ─────────────────────────────────────────────

model MessageEvent {
  id               String    @id @default(uuid())
  messageId        String    @map("message_id")
  eventType        String    @map("event_type")
  eventPayloadJson Json?     @map("event_payload_json")
  occurredAt       DateTime  @map("occurred_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([occurredAt])
  @@map("message_events")
}

// ─────────────────────────────────────────────
// CONVERSATIONS
// ─────────────────────────────────────────────

model Conversation {
  id                String             @id @default(uuid())
  userId            String             @map("user_id")
  leadId            String             @map("lead_id")
  whatsappAccountId String             @map("whatsapp_account_id")
  source            ConversationSource @default(CAMPAIGN)
  lastMessageAt     DateTime?          @map("last_message_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead            Lead                  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  whatsappAccount WhatsappAccount       @relation(fields: [whatsappAccountId], references: [id])
  messages        ConversationMessage[]

  @@unique([userId, leadId, whatsappAccountId])
  @@index([leadId])
  @@index([lastMessageAt])
  @@map("conversations")
}

// ─────────────────────────────────────────────
// CONVERSATION MESSAGES
// ─────────────────────────────────────────────

model ConversationMessage {
  id               String           @id @default(uuid())
  conversationId   String           @map("conversation_id")
  leadId           String           @map("lead_id")
  campaignId       String?          @map("campaign_id")
  messageId        String?          @map("message_id")
  direction        MessageDirection
  body             String
  whatsappMessageId String?         @map("whatsapp_message_id")
  sentAt           DateTime?        @map("sent_at")
  receivedAt       DateTime?        @map("received_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaign     Campaign?    @relation(fields: [campaignId], references: [id])
  message      Message?     @relation(fields: [messageId], references: [id])

  @@index([conversationId])
  @@map("conversation_messages")
}

// ─────────────────────────────────────────────
// ACTIVITY LOGS
// ─────────────────────────────────────────────

model ActivityLog {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  leadId       String?   @map("lead_id")
  campaignId   String?   @map("campaign_id")
  messageId    String?   @map("message_id")
  eventType    EventType @map("event_type")
  description  String
  metadataJson Json?     @map("metadata_json")
  createdAt    DateTime  @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead     Lead?     @relation(fields: [leadId], references: [id])
  campaign Campaign? @relation(fields: [campaignId], references: [id])

  @@index([userId])
  @@index([leadId])
  @@index([campaignId])
  @@map("activity_logs")
}

// ─────────────────────────────────────────────
// ANALYTICS SNAPSHOTS
// ─────────────────────────────────────────────

model AnalyticsSnapshot {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  campaignId       String   @map("campaign_id")
  snapshotDate     DateTime @map("snapshot_date") @db.Date
  totalRecipients  Int      @default(0) @map("total_recipients")
  totalSent        Int      @default(0) @map("total_sent")
  totalDelivered   Int      @default(0) @map("total_delivered")
  totalRead        Int      @default(0) @map("total_read")
  totalReplied     Int      @default(0) @map("total_replied")
  totalConverted   Int      @default(0) @map("total_converted")
  totalFailed      Int      @default(0) @map("total_failed")
  totalUnsubscribed Int     @default(0) @map("total_unsubscribed")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, snapshotDate])
  @@index([snapshotDate])
  @@map("analytics_snapshots")
}
